generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DayStatus {
  ACTIVE
  COMPLETED
  INCOMPLETE
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())

  days      Day[]
}

model Day {
  id          String    @id @default(cuid())
  dayNumber   Int
  title       String
  date        DateTime
  studyTime   Int       @default(0)
  status      DayStatus @default(ACTIVE)
  createdAt   DateTime  @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id])
}